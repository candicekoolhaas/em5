        <Param val="for (var image, _pj_c = 0, _pj_a = productImages, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    image = _pj_a[_pj_c];&amp;#10;    image.setAutoDraw(false);&amp;#10;}&amp;#10;psychoJS.window.saveMovieFrames(&quot;shelf.png&quot;);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="for image in productImages:&amp;#10;    image.setAutoDraw(False)&amp;#10;&amp;#10;win.saveMovieFrames(&quot;shelf.png&quot;)" valType="extendedCode" updates="constant" name="End Routine"/>
