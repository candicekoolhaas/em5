        <Param val="for (var star, _pj_c = 0, _pj_a = stars, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    star = _pj_a[_pj_c];&amp;#10;    star.setAutoDraw(true);&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="for star in stars:&amp;#10;    star.setAutoDraw(True)" valType="extendedCode" updates="constant" name="Begin Routine"/>
