        <Param val="if ((starCounts &gt; 0)) {&amp;#10;    trialFeedback = `Great! You find all six items. Great, you win ${starCounts}`;&amp;#10;} else {&amp;#10;    trialFeedback = &quot;Sorry, you didn't win any sticker.\n Lets try another trial(press Space) &quot;;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
